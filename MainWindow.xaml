<Window x:Class="LiveCaptioner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveCaptioner"
        Height="760"
        Width="1120"
        MinHeight="560"
        MinWidth="860"
        Background="#11131a"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#181c27" Padding="18,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="LiveCaptioner" Foreground="#f4f7fb" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Живые субтитры для микрофона или системного звука: митинги, браузер, YouTube, плееры"
                               Foreground="#9aa7bd"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <CheckBox Grid.Column="1"
                          x:Name="AlwaysOnTopCheckBox"
                          Content="Поверх окон"
                          Foreground="#dce5f3"
                          VerticalAlignment="Center"
                          Checked="AlwaysOnTopCheckBox_Changed"
                          Unchecked="AlwaysOnTopCheckBox_Changed"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#202638" CornerRadius="8" Padding="16" Margin="18,18,18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Grid.Column="0"
                        Content="▶ Старт"
                        Click="StartButton_Click"
                        Background="#2fb36d"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="18,10"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0"/>

                <Button x:Name="StopButton"
                        Grid.Column="1"
                        Content="■ Стоп"
                        Click="StopButton_Click"
                        Background="#c7445b"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="18,10"
                        FontWeight="SemiBold"
                        IsEnabled="False"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                        Content="Очистить"
                        Click="ClearButton_Click"
                        Background="#33405f"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="16,10"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                        Content="Сохранить .txt"
                        Click="SaveButton_Click"
                        Background="#33405f"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="16,10"
                        Margin="0,0,14,0"/>

                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock x:Name="ModelStatusText"
                               Text="Модель Whisper не загружена"
                               Foreground="#dce5f3"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="AudioStatusText"
                               Text="Источник: микрофон"
                               Foreground="#9aa7bd"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="5" VerticalAlignment="Center">
                    <TextBlock Text="УРОВЕНЬ ЗВУКА" Foreground="#9aa7bd" FontSize="11" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="AudioLevelBar"
                                 Minimum="0"
                                 Maximum="1"
                                 Height="12"
                                 Value="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="18,0,18,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#080b12" BorderBrush="#2b3552" BorderThickness="1" CornerRadius="8" Padding="14">
                <ScrollViewer x:Name="CaptionScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="CaptionPanel"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="#181c27" CornerRadius="8" Padding="14" Margin="12,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Настройки" Foreground="#f4f7fb" FontSize="17" FontWeight="SemiBold"/>

                    <TextBlock Text="Общие" Foreground="#7cd4ff" FontSize="12" FontWeight="SemiBold" Margin="0,16,0,0"/>
                    <TextBlock Text="Источник звука" Foreground="#9aa7bd" FontSize="11" Margin="0,18,0,5"/>
                    <ComboBox x:Name="AudioSourceComboBox" SelectedIndex="0" SelectionChanged="AudioSourceComboBox_SelectionChanged">
                        <ComboBoxItem Content="Микрофон"/>
                        <ComboBoxItem Content="Системный звук Windows"/>
                    </ComboBox>

                    <TextBlock Text="Язык" Foreground="#9aa7bd" FontSize="11" Margin="0,18,0,5"/>
                    <ComboBox x:Name="LanguageComboBox" SelectedIndex="1" SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="auto"/>
                        <ComboBoxItem Content="ru"/>
                        <ComboBoxItem Content="en"/>
                        <ComboBoxItem Content="uk"/>
                    </ComboBox>

                    <TextBlock Text="Движок распознавания" Foreground="#9aa7bd" FontSize="11" Margin="0,18,0,5"/>
                    <ComboBox x:Name="EngineComboBox" SelectedIndex="3" SelectionChanged="EngineComboBox_SelectionChanged">
                        <ComboBoxItem Content="Whisper balanced" Tag="whisper-balanced"/>
                        <ComboBoxItem Content="Whisper fast / raw" Tag="whisper-fast"/>
                        <ComboBoxItem Content="Windows Speech Recognition" Tag="windows-speech"/>
                        <ComboBoxItem Content="Vosk local" Tag="vosk-local"/>
                    </ComboBox>

                    <StackPanel x:Name="VoskSettingsPanel" Margin="0,18,0,0">
                        <TextBlock Text="Vosk local" Foreground="#7cd4ff" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VoskModelStatusText"
                                   Text="Vosk model status"
                                   Foreground="#9aa7bd"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>

                        <CheckBox x:Name="VoskPartialResultsCheckBox"
                                  Content="Быстрый live-текст"
                                  IsChecked="True"
                                  Foreground="#dce5f3"
                                  Margin="0,10,0,0"/>

                        <CheckBox x:Name="VoskInterviewVocabularyCheckBox"
                                  Content="Словарь для интервью"
                                  IsChecked="False"
                                  Foreground="#dce5f3"
                                  Margin="0,6,0,0"/>

                        <TextBlock x:Name="VoskSystemAudioGainLabel" Text="Усиление системного звука" Foreground="#9aa7bd" FontSize="11" Margin="0,12,0,5"/>
                        <Slider x:Name="VoskSystemAudioGainSlider" Minimum="0.5" Maximum="4" Value="1.6" TickFrequency="0.25" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="VoskSystemAudioGainValueText"
                                   Text="{Binding ElementName=VoskSystemAudioGainSlider, Path=Value, StringFormat={}{0:0.00}x}"
                                   Foreground="#dce5f3"
                                   FontSize="12"/>

                        <CheckBox x:Name="VoskSystemNoiseGateCheckBox"
                                  Content="Шумовой порог для системного звука"
                                  IsChecked="True"
                                  Foreground="#dce5f3"
                                  Margin="0,6,0,0"/>

                        <CheckBox x:Name="VoskAutoSpeakerTurnsCheckBox"
                                  Content="Делить роли по паузам"
                                  IsChecked="True"
                                  Foreground="#dce5f3"
                                  Margin="0,6,0,0"/>

                        <CheckBox x:Name="VoskSpeakerVectorsCheckBox"
                                  Content="Различать роли по голосу"
                                  IsChecked="True"
                                  Foreground="#dce5f3"
                                  Margin="0,6,0,0"/>

                        <TextBlock x:Name="VoskSpeakerVectorThresholdLabel" Text="Порог похожести голосов" Foreground="#9aa7bd" FontSize="11" Margin="0,12,0,5"/>
                        <Slider x:Name="VoskSpeakerVectorThresholdSlider" Minimum="0.55" Maximum="0.95" Value="0.82" TickFrequency="0.01" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="VoskSpeakerVectorThresholdValueText"
                                   Text="{Binding ElementName=VoskSpeakerVectorThresholdSlider, Path=Value, StringFormat={}{0:0.00}}"
                                   Foreground="#dce5f3"
                                   FontSize="12"/>

                        <TextBlock x:Name="VoskSpeakerPauseLabel" Text="Пауза смены роли" Foreground="#9aa7bd" FontSize="11" Margin="0,12,0,5"/>
                        <Slider x:Name="VoskSpeakerPauseSlider" Minimum="0.8" Maximum="3" Value="1.4" TickFrequency="0.2" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="VoskSpeakerPauseValueText"
                                   Text="{Binding ElementName=VoskSpeakerPauseSlider, Path=Value, StringFormat={}{0:0.0} сек.}"
                                   Foreground="#dce5f3"
                                   FontSize="12"/>

                        <CheckBox x:Name="VoskSentenceFormattingCheckBox"
                                  Content="Форматировать предложения"
                                  IsChecked="True"
                                  Foreground="#dce5f3"
                                  Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="WhisperSettingsPanel" Margin="0,18,0,0">
                        <TextBlock Text="Whisper" Foreground="#7cd4ff" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="Модель Whisper" Foreground="#9aa7bd" FontSize="11" Margin="0,10,0,5"/>
                        <ComboBox x:Name="ModelComboBox" SelectedIndex="0" SelectionChanged="ModelComboBox_SelectionChanged">
                            <ComboBoxItem Content="base - быстрее, ниже точность" Tag="base"/>
                            <ComboBoxItem Content="small - точнее, медленнее" Tag="small"/>
                        </ComboBox>

                        <TextBlock Text="Длина аудио-куска, сек." Foreground="#9aa7bd" FontSize="11" Margin="0,16,0,5"/>
                        <Slider x:Name="ChunkSecondsSlider" Minimum="1" Maximum="8" Value="3" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding ElementName=ChunkSecondsSlider, Path=Value, StringFormat={}{0:0} сек.}"
                                   Foreground="#dce5f3"
                                   FontSize="12"/>

                        <Button x:Name="DownloadModelButton"
                                Content="Скачать base-модель"
                                Click="DownloadModelButton_Click"
                                Background="#33405f"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="14,9"
                                Margin="0,20,0,0"/>

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#9aa7bd"
                                   FontSize="12"
                                   Margin="0,16,0,0"
                                   Text="Whisper использует ggml-модели в папке C:\Projects\LiveCaptioner\Models."/>
                    </StackPanel>

                    <StackPanel x:Name="WindowsSpeechSettingsPanel" Margin="0,18,0,0">
                        <TextBlock Text="Windows Speech" Foreground="#7cd4ff" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#9aa7bd"
                                   FontSize="12"
                                   Margin="0,8,0,0"
                                   Text="Использует встроенный Windows Speech Recognition и только микрофон. Специальных настроек пока нет."/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#181c27" Padding="18,10">
            <TextBlock x:Name="StatusText" Text="Готово." Foreground="#9aa7bd" FontSize="12"/>
        </Border>
    </Grid>
</Window>
